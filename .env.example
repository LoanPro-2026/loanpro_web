# =============================================
# CLERK AUTHENTICATION
# =============================================
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Webhook secret for automatic user creation (Clerk Dashboard -> Webhooks)
# Required for Phase 1 auth fixes - see CLERK_WEBHOOK_SETUP.md
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# =============================================
# DATABASE
# =============================================
# MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# =============================================
# PAYMENT GATEWAY (Razorpay)
# =============================================
# Razorpay credentials - get from https://dashboard.razorpay.com
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_key_here
RAZORPAY_KEY_ID=rzp_live_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Webhook signature secret from Razorpay Dashboard -> Settings -> Webhooks
# Leave as placeholder for development
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# =============================================
# APPLICATION
# =============================================
# API Base URL
NEXT_PUBLIC_API_URL=https://www.loanpro.tech

# Node environment
NODE_ENV=development

# =============================================
# SECURITY
# =============================================
# JWT Secret for token signing (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here

# =============================================
# SUPPORT SYSTEM (Brevo Email Service)
# =============================================
# Get API key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here

# Comma-separated list of admin/support emails for ticket notifications
ADMIN_EMAILS=admin@loanpro.tech,support@loanpro.tech

# =============================================
# OPTIONAL: Other Integrations
# =============================================
# Add any other environment variables your app needs here
